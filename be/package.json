{
  "name": "smartfit-api",
  "version": "1.0.0",
  "description": "E-Commerce REST API — Node.js · Express 5 · PostgreSQL · TypeScript",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "seed": "npx tsx node_modules/knex/bin/cli.js seed:run",
    "makeghn": "node sql/ghn_locations_seed.js",
    "dev": "tsx watch server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@types/multer-s3": "^3.0.3",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "glob": "^13.0.6",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "js-yaml": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.3.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "multer-s3": "^3.0.1",
    "p-queue": "^9.3.1",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "vnpay": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/swagger-ui-express": "^4.1.8",
    "openapi-types": "^12.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
